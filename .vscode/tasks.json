    "version": "2.0.0",
    "tasks": [
        {
            "label": "rbmi - Vignettes",
            "command": "${workspaceFolder}/tests/scripts/vignettes.sh",
            "group": "test",
            "presentation": { "clear": true, "panel": "dedicated" },
            "problemMatcher": "$testthat",
            "options": { "cwd": "${workspaceFolder}" }
        },
        {
            "label": "rbmi - Documentation",
            "command": "${workspaceFolder}/tests/scripts/documentation.sh",
            "group": "test",
            "presentation": { "clear": true, "panel": "dedicated" },
            "problemMatcher": "$testthat",
            "options": { "cwd": "${workspaceFolder}" }
        },
        {
            "label": "rbmi - CRAN",
            "command": "${workspaceFolder}/tests/scripts/cran.sh",
            "group": "test",
            "presentation": { "clear": true, "panel": "dedicated" },
            "problemMatcher": "$testthat",
            "options": { "cwd": "${workspaceFolder}" }
        },
        {
            "label": "rbmi - Core tests",
            "command": "${workspaceFolder}/tests/scripts/core.sh",
            "group": "test",
            "presentation": { "clear": true, "panel": "dedicated" },
            "problemMatcher": "$testthat",
            "options": { "cwd": "${workspaceFolder}" }
        },
        {
            "label": "rbmi - Extended tests",
            "command": "${workspaceFolder}/tests/scripts/extended.sh",
            "group": "test",
            "presentation": { "clear": true, "panel": "dedicated" },
            "problemMatcher": "$testthat",
            "options": { "cwd": "${workspaceFolder}" }
        },
        {
            "label": "rbmi - All tests",
            "dependsOn": [
                "rbmi - Vignettes",
                "rbmi - Documentation",
                "rbmi - CRAN",
                "rbmi - Core tests"
            ],
            "group": "test",
            "problemMatcher": []
        }
    ]
}